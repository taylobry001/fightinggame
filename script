# ==================== DEV MENU ====================
class DevMenu:
    def __init__(self, screen, fighters):
        self.screen = screen
        self.fighters = fighters
        self.running = True
        self.selected_fighter = 0
        self.selected_option = 0

        self.options = [
            "Infinite Ultimate",
            "One Hit Kill",
            "Invincibility",
            "Fill Ultimate Meter",
            "Add Stock",
            "Remove Stock",
            "Spawn Jotaro (P1)",
            "Spawn Star Platinum (P2)",
            "Change Background",
            "Exit Dev Menu"
        ]

    def handle_input(self, keys):
        if keys[pygame.K_UP]:
            self.selected_option = (self.selected_option - 1) % len(self.options)
            pygame.time.wait(150)
        elif keys[pygame.K_DOWN]:
            self.selected_option = (self.selected_option + 1) % len(self.options)
            pygame.time.wait(150)
        elif keys[pygame.K_LEFT]:
            self.selected_fighter = 0
        elif keys[pygame.K_RIGHT]:
            self.selected_fighter = 1
        elif keys[pygame.K_RETURN]:
            self.apply_option()
        elif keys[pygame.K_ESCAPE]:
            self.running = False

    def apply_option(self):
        fighter = self.fighters[self.selected_fighter]

        if self.selected_option == 0:  # Infinite Ultimate
            fighter.dev_infinite_ult = not fighter.dev_infinite_ult
        elif self.selected_option == 1:  # One Hit Kill
            fighter.dev_one_hit_kill = not fighter.dev_one_hit_kill
        elif self.selected_option == 2:  # Invincibility
            fighter.dev_invincible = not fighter.dev_invincible
        elif self.selected_option == 3:  # Fill Ultimate
            fighter.ult_meter = fighter.ult_max
        elif self.selected_option == 4:  # Add Stock
            fighter.stocks += 1
        elif self.selected_option == 5:  # Remove Stock
            fighter.stocks = max(1, fighter.stocks - 1)
        elif self.selected_option == 6:  # Spawn Jotaro
            if self.selected_fighter == 0:
                self.fighters[0] = Fighter(300, SCREEN_HEIGHT - 150, DEV_CHARACTERS[0], 0)
        elif self.selected_option == 7:  # Spawn Star Platinum
            if self.selected_fighter == 1:
                self.fighters[1] = Fighter(SCREEN_WIDTH - 300, SCREEN_HEIGHT - 150, DEV_CHARACTERS[1], 1)
        elif self.selected_option == 8:  # Change Background
            # Handled by main game
            pass
        elif self.selected_option == 9:  # Exit
            self.running = False

    def draw(self):
        # Dark overlay
        overlay = pygame.Surface((SCREEN_WIDTH, SCREEN_HEIGHT))
        overlay.set_alpha(200)
        overlay.fill(BLACK)
        self.screen.blit(overlay, (0, 0))

        # Title
        font = pygame.font.Font(None, 72)
        title = font.render("DEV MENU", True, GOLD)
        title_rect = title.get_rect(center=(SCREEN_WIDTH // 2, 80))
        self.screen.blit(title, title_rect)

        # Fighter selector
        selector_font = pygame.font.Font(None, 48)
        p1_color = GREEN if self.selected_fighter == 0 else RED
        p2_color = GREEN if self.selected_fighter == 1 else BLUE

        p1_text = selector_font.render(f"P1: {self.fighters[0].stats.name}", True, p1_color)
        p2_text = selector_font.render(f"P2: {self.fighters[1].stats.name}", True, p2_color)

        self.screen.blit(p1_text, (300, 150))
        self.screen.blit(p2_text, (SCREEN_WIDTH - 400, 150))

        # Options
        y = 220
        for i, option in enumerate(self.options):
            color = GREEN if i == self.selected_option else WHITE
            text = pygame.font.Font(None, 36).render(option, True, color)
            self.screen.blit(text, (SCREEN_WIDTH // 2 - text.get_width() // 2, y))
            y += 45

        # Current fighter stats
        fighter = self.fighters[self.selected_fighter]
        stats_y = 500
        stats_font = pygame.font.Font(None, 24)

        ult_text = f"Infinite Ult: {'ON' if fighter.dev_infinite_ult else 'OFF'}"
        ohk_text = f"One Hit Kill: {'ON' if fighter.dev_one_hit_kill else 'OFF'}"
        inv_text = f"Invincible: {'ON' if fighter.dev_invincible else 'OFF'}"

        self.screen.blit(stats_font.render(ult_text, True, LIGHT_GRAY), (400, stats_y))
        self.screen.blit(stats_font.render(ohk_text, True, LIGHT_GRAY), (400, stats_y + 25))
        self.screen.blit(stats_font.render(inv_text, True, LIGHT_GRAY), (400, stats_y + 50))

        # Controls
        controls = pygame.font.Font(None, 24).render(
            "UP/DOWN: Navigate, LEFT/RIGHT: Select Fighter, ENTER: Apply, ESC: Close",
            True, LIGHT_GRAY)
        controls_rect = controls.get_rect(center=(SCREEN_WIDTH // 2, 650))
        self.screen.blit(controls, controls_rect)

        pygame.display.flip()

    def run(self):
        while self.running:
            for event in pygame.event.get():
                if event.type == pygame.QUIT:
                    return None

            keys = pygame.key.get_pressed()
            self.handle_input(keys)
            self.draw()

        return True


