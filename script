# ==================== PNG BACKGROUND SUPPORT ====================
class PNGBackground:
    def __init__(self, image_path, scroll_speed=0):
        self.image = None
        self.scroll_speed = scroll_speed
        self.scroll_x = 0
        self.scroll_y = 0
        self.load_image(image_path)

    def load_image(self, image_path):
        """Load a PNG image for background"""
        try:
            if os.path.exists(image_path):
                self.image = pygame.image.load(image_path)
                self.image = pygame.transform.scale(self.image, (SCREEN_WIDTH, SCREEN_HEIGHT))
                print(f"Loaded background: {image_path}")
            else:
                print(f"Background image not found: {image_path}")
                self.image = None
        except:
            print(f"Failed to load background: {image_path}")
            self.image = None

    def update(self):
        if self.scroll_speed != 0:
            self.scroll_x += self.scroll_speed
            if abs(self.scroll_x) > SCREEN_WIDTH:
                self.scroll_x = 0

    def draw(self, screen):
        if self.image:
            screen.blit(self.image, (self.scroll_x, self.scroll_y))
            if self.scroll_speed != 0:
                screen.blit(self.image, (self.scroll_x - SCREEN_WIDTH, self.scroll_y))
        else:
            # Fallback to gradient if image not loaded
            for i in range(SCREEN_HEIGHT):
                color = (50, 50 + i // 10, 100)
                pygame.draw.line(screen, color, (0, i), (SCREEN_WIDTH, i))


# ==================== BACKGROUND SYSTEM ====================
class BackgroundEffect:
    def __init__(self, name, color1, color2, particles=False, parallax=False, png_path=None):
        self.name = name
        self.color1 = color1
        self.color2 = color2
        self.particles = particles
        self.parallax = parallax
        self.png_path = png_path
        self.time = 0
        self.particles_list = []
        self.png_bg = None

        if png_path:
            self.png_bg = PNGBackground(png_path)

        if particles:
            for _ in range(50):
                self.particles_list.append({
                    'x': random.randint(0, SCREEN_WIDTH),
                    'y': random.randint(0, SCREEN_HEIGHT),
                    'speed': random.uniform(0.5, 2),
                    'size': random.randint(2, 6),
                    'color': random.choice([color1, color2, WHITE])
                })

    def update(self):
        self.time += 0.01
        if self.png_bg:
            self.png_bg.update()

        if self.particles:
            for p in self.particles_list:
                p['y'] += p['speed']
                if p['y'] > SCREEN_HEIGHT:
                    p['y'] = 0
                    p['x'] = random.randint(0, SCREEN_WIDTH)

    def draw(self, screen):
        if self.png_bg and self.png_bg.image:
            self.png_bg.draw(screen)
            return

        if self.name == "gradient":
            # Gradient background
            for i in range(SCREEN_HEIGHT):
                color = [
                    int(self.color1[0] + (self.color2[0] - self.color1[0]) * i / SCREEN_HEIGHT),
                    int(self.color1[1] + (self.color2[1] - self.color1[1]) * i / SCREEN_HEIGHT),
                    int(self.color1[2] + (self.color2[2] - self.color1[2]) * i / SCREEN_HEIGHT)
                ]
                pygame.draw.line(screen, color, (0, i), (SCREEN_WIDTH, i))

        elif self.name == "stars":
            screen.fill(BLACK)
            for i in range(100):
                x = (i * 13 + int(self.time * 10)) % SCREEN_WIDTH
                y = (i * 7) % SCREEN_HEIGHT
                brightness = int(128 + 127 * math.sin(i + self.time * 5))
                pygame.draw.circle(screen, (brightness, brightness, brightness), (x, y), 2)

        elif self.name == "fire":
            screen.fill((10, 10, 10))
            for i in range(20):
                y_offset = int(math.sin(self.time * 2 + i) * 20)
                color_shift = int(128 + 127 * math.sin(self.time * 3 + i))
                pygame.draw.rect(screen,
                                 (255, color_shift, 0),
                                 (i * 64, SCREEN_HEIGHT - 100 + y_offset, 64, 100))

        elif self.name == "water":
            screen.fill((0, 20, 40))
            for i in range(10):
                wave = int(math.sin(self.time * 2 + i * 0.5) * 30)
                pygame.draw.rect(screen,
                                 (0, 100 + wave, 200),
                                 (0, i * 80, SCREEN_WIDTH, 40), 2)

        elif self.name == "space":
            screen.fill((5, 5, 15))
            for i in range(200):
                x = (i * 23) % SCREEN_WIDTH
                y = (i * 17 + int(self.time * 20)) % SCREEN_HEIGHT
                color = (random.randint(100, 200),
                         random.randint(50, 150),
                         random.randint(150, 255))
                pygame.draw.circle(screen, color, (x, y), 1)

        # Draw particles if enabled
        if self.particles:
            for p in self.particles_list:
                pygame.draw.circle(screen, p['color'], (int(p['x']), int(p['y'])), p['size'])


