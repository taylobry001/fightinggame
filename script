            bg_text = pygame.font.Font(None, 24).render(
                f"Background: {self.bg_list[self.background_index]}", True, LIGHT_GRAY)
            bg_rect = bg_text.get_rect(center=(SCREEN_WIDTH // 2, 180))
            self.screen.blit(bg_text, bg_rect)

            # Draw background cycle buttons
            self.bg_left.draw(self.screen)
            self.bg_right.draw(self.screen)

            # Draw main buttons
            for button in self.buttons:
                button.draw(self.screen)

            # AI difficulty slider
            if self.show_difficulty:
                # Dark overlay
                overlay = pygame.Surface((SCREEN_WIDTH, SCREEN_HEIGHT))
                overlay.set_alpha(200)
                overlay.fill(BLACK)
                self.screen.blit(overlay, (0, 0))

                # Difficulty box
