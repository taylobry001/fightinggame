class Game:
    def __init__(self, screen, mode, background, p1_char=None, p2_char=None, ai_difficulty=0.5):
        self.screen = screen
        self.clock = pygame.time.Clock()
        self.running = True
        self.mode = mode
        self.background = background
        self.ai_difficulty = ai_difficulty
        self.dev_menu_active = False
        self.dev_menu = None

        # Create platforms
        self.platforms = [
            (0, SCREEN_HEIGHT - 80, SCREEN_WIDTH, 20),
            (SCREEN_WIDTH // 2 - 150, SCREEN_HEIGHT - 300, 300, 20),
            (SCREEN_WIDTH // 2 - 100, SCREEN_HEIGHT - 500, 200, 20)
        ]

        # Create fighters
        if p1_char and p2_char:
            self.fighters = [
                Fighter(300, SCREEN_HEIGHT - 150, p1_char, 0),
                Fighter(SCREEN_WIDTH - 300, SCREEN_HEIGHT - 150, p2_char, 1)
            ]
        else:
            self.fighters = [
                Fighter(300, SCREEN_HEIGHT - 150, CHARACTERS[0], 0),
                Fighter(SCREEN_WIDTH - 300, SCREEN_HEIGHT - 150, CHARACTERS[1], 1)
            ]

        # Set AI for second fighter if needed
        if mode == GameMode.VS_AI:
            self.fighters[1].is_ai = True
            self.ai = AIController(ai_difficulty)

    def handle_events(self):
        for event in pygame.event.get():
            if event.type == pygame.QUIT:
                self.running = False
            elif event.type == pygame.KEYDOWN:
                if event.key == pygame.K_ESCAPE:
                    if self.dev_menu_active:
                        self.dev_menu_active = False
                    else:
                        self.running = False
                elif event.key == pygame.K_F1:  # F1 to open dev menu
                    self.dev_menu_active = True
                    self.dev_menu = DevMenu(self.screen, self.fighters)

    def handle_input(self):
        keys = pygame.key.get_pressed()

        if self.dev_menu_active:
            return

        # Player 1
        p1 = self.fighters[0]
        p1.move_left = keys[pygame.K_LEFT]
        p1.move_right = keys[pygame.K_RIGHT]
        p1.press_jump = keys[pygame.K_UP]
        p1.press_attack = keys[pygame.K_j]
        p1.press_special = keys[pygame.K_k]
        p1.press_ult = keys[pygame.K_l]

        # Player 2 (if human)
        if len(self.fighters) > 1 and self.mode == GameMode.LOCAL_VS:
            p2 = self.fighters[1]
            p2.move_left = keys[pygame.K_a]
            p2.move_right = keys[pygame.K_d]
            p2.press_jump = keys[pygame.K_w]
            p2.press_attack = keys[pygame.K_u]
            p2.press_special = keys[pygame.K_i]
            p2.press_ult = keys[pygame.K_o]

    def update(self):
        if self.dev_menu_active:
            result = self.dev_menu.run()
            if result is None:
                self.dev_menu_active = False
            return

        # Process AI if needed
        if self.mode == GameMode.VS_AI and len(self.fighters) > 1:
            ai_inputs = self.ai.get_inputs(self.fighters[1], self.fighters[0])
            ai_fighter = self.fighters[1]
            ai_fighter.move_left = ai_inputs['left']
            ai_fighter.move_right = ai_inputs['right']
            ai_fighter.press_jump = ai_inputs['jump']
            ai_fighter.press_attack = ai_inputs['attack']
            ai_fighter.press_special = ai_inputs['special']
            ai_fighter.press_ult = ai_inputs['ult']

        # Update fighters
        for fighter in self.fighters:
            fighter.update(self.platforms, self.fighters)

        # Update background
        self.background.update()

    def draw(self):
        # Draw background
        self.background.draw(self.screen)

        # Draw platforms
        for platform in self.platforms:
            pygame.draw.rect(self.screen, GRAY, platform)
            pygame.draw.rect(self.screen, LIGHT_GRAY, platform, 2)

        # Draw fighters
        for fighter in self.fighters:
            fighter.draw(self.screen)

        # Draw UI
        font = pygame.font.Font(None, 24)

        # Mode
        mode_text = f"Mode: {self.mode.value}"
        if self.mode == GameMode.VS_AI:
            mode_text += f" (Difficulty: {self.ai_difficulty:.1f})"
        text = font.render(mode_text, True, WHITE)
        self.screen.blit(text, (10, 10))

        # Dev menu hint
        if any(f.dev_infinite_ult or f.dev_one_hit_kill for f in self.fighters):
            dev_text = font.render("DEV MODE ACTIVE - Press F1 for menu", True, GOLD)
            self.screen.blit(dev_text, (SCREEN_WIDTH // 2 - dev_text.get_width() // 2, 10))

        # Controls
        controls = font.render("J: Attack, K: Special, L: Ultimate", True, LIGHT_GRAY)
        self.screen.blit(controls, (SCREEN_WIDTH - 300, 10))

        # Game over
        alive = [f for f in self.fighters if f.stocks > 0]
        if len(alive) <= 1:
            if len(alive) == 1:
                winner_text = f"{alive[0].stats.name} WINS!"
            else:
                winner_text = "DRAW!"

            big_font = pygame.font.Font(None, 72)
            text = big_font.render(winner_text, True, YELLOW)
            text_rect = text.get_rect(center=(SCREEN_WIDTH // 2, SCREEN_HEIGHT // 2))
            self.screen.blit(text, text_rect)

            prompt = pygame.font.Font(None, 36).render("Press ESC to return to menu", True, LIGHT_GRAY)
            prompt_rect = prompt.get_rect(center=(SCREEN_WIDTH // 2, SCREEN_HEIGHT // 2 + 80))
            self.screen.blit(prompt, prompt_rect)

        pygame.display.flip()

    def run(self):
        while self.running:
            self.handle_events()
            self.handle_input()
            self.update()
            self.draw()
            self.clock.tick(FPS)
        return


# ==================== AI CONTROLLER ====================
class AIController:
    def __init__(self, difficulty=0.5):
        self.difficulty = difficulty
        self.attack_timer = 0

    def get_inputs(self, ai_fighter, opponent):
        if not opponent or ai_fighter.hitstun > 0:
            return {'left': False, 'right': False, 'jump': False,
                    'attack': False, 'special': False, 'ult': False}

        self.attack_timer = max(0, self.attack_timer - 1)

        dx = opponent.x - ai_fighter.x
        dy = opponent.y - ai_fighter.y
        distance = abs(dx)

        inputs = {'left': False, 'right': False, 'jump': False,
                  'attack': False, 'special': False, 'ult': False}

        if random.random() < self.difficulty:
            # Movement
            if distance > 100:
                if dx > 0:
                    inputs['right'] = True
                else:
                    inputs['left'] = True
            elif distance < 50:
                if dx > 0:
                    inputs['left'] = True
                else:
                    inputs['right'] = True

            # Jump
            if dy < -30 and ai_fighter.on_ground and random.random() < 0.05:
                inputs['jump'] = True

            # Attacks
            if distance < 80 and self.attack_timer == 0:
                if random.random() < 0.3:
                    inputs['attack'] = True
                    self.attack_timer = 30
                elif random.random() < 0.2:
                    inputs['special'] = True
                    self.attack_timer = 40

            # Ultimate
            if ai_fighter.ult_meter >= ai_fighter.ult_max and random.random() < 0.1:
                inputs['ult'] = True

        return inputs


# ==================== SETTINGS MENU ====================
class SettingsMenu:
    def __init__(self, screen):
        self.screen = screen
        self.running = True
        self.selected_option = 0
        self.options = ["Back"]

    def run(self):
        while self.running:
            for event in pygame.event.get():
                if event.type == pygame.QUIT:
                    return None
                elif event.type == pygame.KEYDOWN:
                    if event.key == pygame.K_ESCAPE:
                        self.running = False

            self.screen.fill(DARK_GRAY)
            font = pygame.font.Font(None, 48)
            text = font.render("Settings (Placeholder)", True, WHITE)
            text_rect = text.get_rect(center=(SCREEN_WIDTH // 2, SCREEN_HEIGHT // 2))
            self.screen.blit(text, text_rect)

            pygame.display.flip()

        return self


# ==================== MAIN FUNCTION ====================
def main():
    screen = pygame.display.set_mode((SCREEN_WIDTH, SCREEN_HEIGHT))
    pygame.display.set_caption("Simple Fighter - Ultimate Edition")

    while True:
        # Main menu
        menu = MainMenu(screen)
        result = menu.run()

        if result is None:  # Quit
            break

        elif result == "settings":
            settings = SettingsMenu(screen)
            settings.run()
            continue

        elif result == GameMode.DEV_MENU:
            # Character select with dev characters
            char_select = CharacterSelect(screen, menu.current_bg, is_dev_mode=True)
            characters = char_select.run()

            if characters is None:
                continue

            p1_char, p2_char = characters

            # Start game in dev mode
            game = Game(screen, GameMode.LOCAL_VS, menu.current_bg, p1_char, p2_char)
            game.run()

        elif result in [GameMode.LOCAL_VS, GameMode.VS_AI]:
            # Character select (normal mode)
            char_select = CharacterSelect(screen, menu.current_bg, is_dev_mode=False)
            characters = char_select.run()

            if characters is None:
                continue

            p1_char, p2_char = characters

            # Start game
            if result == GameMode.VS_AI:
                game = Game(screen, result, menu.current_bg, p1_char, p2_char, menu.ai_difficulty)
            else:
                game = Game(screen, result, menu.current_bg, p1_char, p2_char)

            game.run()

    pygame.quit()


if __name__ == "__main__":
    main()
