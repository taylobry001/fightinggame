class Game:
    def __init__(self, screen, mode, background, p1_char=None, p2_char=None, ai_difficulty=0.5):
        self.screen = screen
        self.clock = pygame.time.Clock()
        self.running = True
        self.mode = mode
        self.background = background
        self.ai_difficulty = ai_difficulty
        self.screen_shake = 0
        
        # Create platforms
        self.platforms = [
            (0, SCREEN_HEIGHT - 80, SCREEN_WIDTH, 20),
            (SCREEN_WIDTH//2 - 150, SCREEN_HEIGHT - 300, 300, 20),
            (SCREEN_WIDTH//2 - 100, SCREEN_HEIGHT - 500, 200, 20)
        ]
        
        # Create fighters
        if p1_char and p2_char:
            self.fighters = [
                Fighter(300, SCREEN_HEIGHT - 150, p1_char, 0),
                Fighter(SCREEN_WIDTH - 300, SCREEN_HEIGHT - 150, p2_char, 1)
            ]
        else:
            self.fighters = [
                Fighter(300, SCREEN_HEIGHT - 150, CHARACTERS[0], 0),
                Fighter(SCREEN_WIDTH - 300, SCREEN_HEIGHT - 150, CHARACTERS[1], 1)
            ]
            
        # Set AI for second fighter if needed
        if mode == GameMode.VS_AI:
            self.fighters[1].is_ai = True
            self.ai = AIController(ai_difficulty)
            
        # Music placeholder (you can add your music files later)
        self.music_playing = False
        
    def play_music(self, music_file):
        """Placeholder for music - you can add your music files here"""
        # pygame.mixer.music.load(music_file)
        # pygame.mixer.music.play(-1)
        pass
        
    def handle_events(self):
        for event in pygame.event.get():
            if event.type == pygame.QUIT:
                self.running = False
            elif event.type == pygame.KEYDOWN:
                if event.key == pygame.K_ESCAPE:
                    self.running = False
                    
    def handle_input(self):
        keys = pygame.key.get_pressed()
        
        # Player 1 (simplified controls)
        p1 = self.fighters[0]
        
        # Movement
        p1.move_left = keys[pygame.K_LEFT]
        p1.move_right = keys[pygame.K_RIGHT]
        
        # Jump
        if keys[pygame.K_UP]:
            p1.press_jump = True
            
        # Attacks (simplified - just two buttons)
        p1.press_attack = keys[pygame.K_j]
        p1.press_special = keys[pygame.K_k]
        p1.press_ult = keys[pygame.K_l]
        
        # Player 2 (if human)
        if len(self.fighters) > 1 and self.mode == GameMode.LOCAL_VS:
            p2 = self.fighters[1]
            
            p2.move_left = keys[pygame.K_a]
            p2.move_right = keys[pygame.K_d]
            
            if keys[pygame.K_w]:
                p2.press_jump = True
                
            p2.press_attack = keys[pygame.K_u]
            p2.press_special = keys[pygame.K_i]
            p2.press_ult = keys[pygame.K_o]
            
    def update(self):
        # Process AI if needed
        if self.mode == GameMode.VS_AI and len(self.fighters) > 1:
            ai_inputs = self.ai.get_inputs(self.fighters[1], self.fighters[0])
            ai_fighter = self.fighters[1]
            ai_fighter.move_left = ai_inputs['left']
            ai_fighter.move_right = ai_inputs['right']
            ai_fighter.press_jump = ai_inputs['jump']
            ai_fighter.press_attack = ai_inputs['attack']
            ai_fighter.press_special = ai_inputs['special']
            ai_fighter.press_ult = ai_inputs['ult']
            
        # Update fighters
        for fighter in self.fighters:
            fighter.update(self.platforms, self.fighters)
            
        # Update background
        self.background.update()
        
        # Screen shake
        if self.screen_shake > 0:
            self.screen_shake -= 1
            
    def draw(self):
        # Draw background
        if self.screen_shake > 0:
            shake_x = random.randint(-5, 5)
            shake_y = random.randint(-5, 5)
            self.screen.blit(self.background, (shake_x, shake_y))
        else:
            self.background.draw(self.screen)
            
        # Draw platforms
        for platform in self.platforms:
            pygame.draw.rect(self.screen, GRAY, platform)
            pygame.draw.rect(self.screen, LIGHT_GRAY, platform, 2)
            
        # Draw fighters
        for fighter in self.fighters:
            fighter.draw(self.screen)
            
        # Draw mode
        font = pygame.font.Font(None, 24)
        mode_text = f"Mode: {self.mode.value}"
        if self.mode == GameMode.VS_AI:
            mode_text += f" (Difficulty: {self.ai_difficulty:.1f})"
        text = font.render(mode_text, True, WHITE)
        self.screen.blit(text, (10, 10))
        
        # Draw controls reminder
        controls = font.render("J: Attack, K: Special, L: Ultimate", True, LIGHT_GRAY)
        self.screen.blit(controls, (SCREEN_WIDTH - 300, 10))
        
        # Draw game over
        alive = [f for f in self.fighters if f.stocks > 0]
        if len(alive) <= 1:
            if len(alive) == 1:
                winner_text = f"{alive[0].stats.name} WINS!"
            else:
                winner_text = "DRAW!"
                
            big_font = pygame.font.Font(None, 72)
            text = big_font.render(winner_text, True, YELLOW)
            text_rect = text.get_rect(center=(SCREEN_WIDTH//2, SCREEN_HEIGHT//2))
            self.screen.blit(text, text_rect)
            
            # Return to menu prompt
            small_font = pygame.font.Font(None, 36)
            prompt = small_font.render("Press ESC to return to menu", True, LIGHT_GRAY)
            prompt_rect = prompt.get_rect(center=(SCREEN_WIDTH//2, SCREEN_HEIGHT//2 + 80))
            self.screen.blit(prompt, prompt_rect)
            
        pygame.display.flip()
        
    def run(self):
        # Placeholder for music (add your music files here)
        # self.play_music("menu_music.mp3")
        
        while self.running:
            self.handle_events()
            self.handle_input()
            self.update()
            self.draw()
            self.clock.tick(FPS)
        return

# ==================== MAIN FUNCTION ====================
def main():
    screen = pygame.display.set_mode((SCREEN_WIDTH, SCREEN_HEIGHT))
    pygame.display.set_caption("Simple Fighter - Ultimate Edition")
    
    settings = None
    
    while True:
        # Main menu
        menu = MainMenu(screen)
        result = menu.run()
        
        if result is None:  # Quit
            break
            
        elif result == "settings":
            settings_menu = SettingsMenu(screen)
            settings = settings_menu.run()
            continue
            
        elif result == "online":
            # Simple room browser (you can expand this)
            browser = RoomBrowser(screen)
            # For now, just go back to menu
            continue
            
        elif result in [GameMode.LOCAL_VS, GameMode.VS_AI]:
            # Character select
            char_select = CharacterSelect(screen, menu.current_bg)
            characters = char_select.run()
            
            if characters is None:  # Back to menu
                continue
                
            p1_char, p2_char = characters
            
            # Start game with selected background
            if result == GameMode.VS_AI:
                game = Game(screen, result, menu.current_bg, p1_char, p2_char, menu.ai_difficulty)
            else:
                game = Game(screen, result, menu.current_bg, p1_char, p2_char)
                
            game.run()
            
    pygame.quit()

if __name__ == "__main__":
    main()
