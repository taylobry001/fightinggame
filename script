# ==================== VFX SYSTEM ====================
class VFX:
    def __init__(self):
        self.effects = []

    def add_hit_effect(self, x, y, color):
        for _ in range(8):
            self.effects.append({
                'x': x,
                'y': y,
                'vx': random.uniform(-5, 5),
                'vy': random.uniform(-5, 5),
                'color': color,
                'size': random.randint(3, 6),
                'life': 20
            })

    def add_ultimate_effect(self, x, y, color):
        for _ in range(20):
            self.effects.append({
                'x': x,
                'y': y,
                'vx': random.uniform(-8, 8),
                'vy': random.uniform(-8, 8),
                'color': color,
                'size': random.randint(4, 8),
                'life': 30
            })

    def add_trail_effect(self, x, y, color):
        self.effects.append({
            'x': x,
            'y': y,
            'vx': random.uniform(-1, 1),
            'vy': random.uniform(-1, 1),
            'color': color,
            'size': random.randint(2, 4),
            'life': 10
        })

    def update(self):
        for effect in self.effects[:]:
            effect['x'] += effect['vx']
            effect['y'] += effect['vy']
            effect['life'] -= 1
            if effect['life'] <= 0:
                self.effects.remove(effect)

    def draw(self, screen):
        for effect in self.effects:
            alpha = int(255 * (effect['life'] / 20))
            color = list(effect['color'])
            pygame.draw.circle(screen, color,
                               (int(effect['x']), int(effect['y'])),
                               effect['size'])


