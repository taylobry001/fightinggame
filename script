# ==================== FIGHTER CLASS WITH VFX ====================
class Fighter:
    def __init__(self, x, y, character_stats, player_id, is_ai=False):
        self.stats = character_stats
        self.id = player_id
        self.is_ai = is_ai

        # Position
        self.x = x
        self.y = y
        self.vx = 0
        self.vy = 0
        self.facing = 1
        self.on_ground = False
        self.jumps_left = 2

        # Combat
        self.damage = 0
        self.stocks = 3
        self.hitstun = 0
        self.invincible = 0

        # Ultimate system
        self.ult_meter = 0
        self.ult_max = 100
        self.ult_active = False
        self.ult_timer = 0
        self.ult_cooldown = 0

        # Dev mode cheats
        self.dev_infinite_ult = False
        self.dev_one_hit_kill = False
        self.dev_invincible = False

        # Input
        self.move_left = False
        self.move_right = False
        self.press_jump = False
        self.press_attack = False
        self.press_special = False
        self.press_ult = False

        # Attack state
        self.attacking = False
        self.attack_type = 0
        self.attack_timer = 0
        self.attack_cooldown = 0

        # Visual
        self.width = 36
        self.height = 54
        self.trail = []

        # VFX
        self.vfx = VFX()

        # Special effects for Jotaro/Star Platinum
        self.stand_active = False
        self.stand_timer = 0

    def update(self, platforms, opponents):
        # Hitstun
        if self.hitstun > 0 and not self.dev_invincible:
            self.hitstun -= 1
            self.x += self.vx * 0.5
            self.y += self.vy * 0.5
            return

        # Invincibility
        if self.invincible > 0:
            self.invincible -= 1

        # Ultimate
        if self.ult_active:
            self.ult_timer -= 1
            if self.ult_timer <= 0 and not self.dev_infinite_ult:
                self.ult_active = False
                self.ult_cooldown = 300

        if self.ult_cooldown > 0 and not self.dev_infinite_ult:
            self.ult_cooldown -= 1

        # Attack cooldown
        if self.attack_cooldown > 0:
            self.attack_cooldown -= 1

        # Attack animation
        if self.attacking:
            self.attack_timer += 1

            # Add hit effect during attack
            if self.attack_timer == 8:
                attack_x = self.x + (self.width if self.facing > 0 else 0)
                self.vfx.add_hit_effect(attack_x, self.y + self.height // 2, self.stats.ult_color)

            if self.attack_timer > 15:
                self.attacking = False
                self.attack_cooldown = 20

        # Movement
        move_input = 0
        if self.move_left:
            move_input = -1
        elif self.move_right:
            move_input = 1

        if move_input != 0:
            speed = self.stats.air_speed if not self.on_ground else self.stats.walk_speed
            self.vx += move_input * speed * 0.3
            self.facing = move_input

        # Friction
        if self.on_ground:
            self.vx *= GROUND_FRICTION
        else:
            self.vx *= AIR_FRICTION

        # Jump
        if self.press_jump and self.jumps_left > 0:
            if self.on_ground:
                self.vy = self.stats.jump_force
                self.jumps_left -= 1
                self.on_ground = False
            elif self.jumps_left > 0:
                self.vy = self.stats.double_jump_force
                self.jumps_left -= 1
            self.press_jump = False

        # Gravity
        if not self.on_ground:
            self.vy += GRAVITY

        # Apply movement
        self.x += self.vx
        self.y += self.vy

        # Platform collision
        self.on_ground = False
        for platform in platforms:
            if (self.x + self.width > platform[0] and
                    self.x < platform[0] + platform[2] and
                    self.y + self.height > platform[1] and
                    self.y + self.height < platform[1] + platform[3] + 10 and
                    self.vy >= 0):
                self.y = platform[1] - self.height
                self.vy = 0
                self.on_ground = True
                self.jumps_left = 2
                break

        # Handle attacks
        if self.press_attack and not self.attacking and self.attack_cooldown <= 0:
            self.attack_type = 0
            self.attacking = True
            self.attack_timer = 0

        if self.press_special and not self.attacking and self.attack_cooldown <= 0:
            self.attack_type = 3
            self.attacking = True
            self.attack_timer = 0

        # Ultimate - can be used anytime with dev mode
        if self.press_ult:
            if self.dev_infinite_ult or (self.ult_meter >= self.ult_max and self.ult_cooldown <= 0):
                self.ult_active = True
                self.ult_timer = 180
                if not self.dev_infinite_ult:
                    self.ult_meter = 0
                # Add ultimate effect
                self.vfx.add_ultimate_effect(self.x + self.width // 2, self.y + self.height // 2, self.stats.ult_color)

        # Ultimate generation
        if not self.dev_infinite_ult:
            if self.ult_active:
                self.ult_meter = min(self.ult_max, self.ult_meter + 0.2)
            else:
                self.ult_meter = min(self.ult_max, self.ult_meter + 0.1)

        # Check for ultimate attack hit
        if self.ult_active:
            self.check_ultimate_hit(opponents)

        # Check for normal attack hits
        if self.attacking and 5 < self.attack_timer < 12:
            self.check_hits(opponents)

        # Trail effect
        if self.ult_active or (self.stats.is_dev and self.ult_active):
            self.trail.append((self.x + self.width // 2, self.y + self.height // 2))
            if len(self.trail) > 10:
                self.trail.pop(0)

            # Add trail VFX
            if random.random() < 0.3:
                self.vfx.add_trail_effect(self.x + self.width // 2, self.y + self.height // 2, self.stats.ult_color)
        else:
            self.trail = []

        # Update VFX
        self.vfx.update()

        # Blast zones
        if (self.x + self.width < BLAST_ZONES['left'] or
                self.x > BLAST_ZONES['right'] or
                self.y + self.height < BLAST_ZONES['top'] or
                self.y > BLAST_ZONES['bottom']):
            self.respawn()

    def get_attack_damage(self):
        if self.dev_one_hit_kill:
            return 999

        if self.ult_active:
            return self.stats.ult_damage

        if self.attack_type == 0:
            return self.stats.jab_damage
        elif self.attack_type == 3:
            return self.stats.special_damage
        return 0

    def get_attack_knockback(self):
        if self.dev_one_hit_kill:
            return 999

        if self.ult_active:
            return self.stats.ult_knockback

        if self.attack_type == 0:
            return self.stats.jab_knockback
        elif self.attack_type == 3:
            return self.stats.special_knockback
        return 0

    def check_hits(self, opponents):
        attack_width = 70 if self.ult_active else 50
        attack_height = 60 if self.ult_active else 40
        attack_x = self.x + (self.width if self.facing > 0 else -attack_width)
        attack_y = self.y + 10

        for opponent in opponents:
            if opponent != self and opponent.hitstun <= 0:
                if opponent.invincible > 0 and not self.dev_one_hit_kill:
                    continue

                if (attack_x < opponent.x + opponent.width and
                        attack_x + attack_width > opponent.x and
                        attack_y < opponent.y + opponent.height and
                        attack_y + attack_height > opponent.y):

                    # Damage
                    damage = self.get_attack_damage()
                    opponent.damage += damage

                    # Add hit effect
                    self.vfx.add_hit_effect(opponent.x + opponent.width // 2,
                                            opponent.y + opponent.height // 2,
                                            self.stats.ult_color)

                    # Gain ultimate meter
                    if not self.dev_infinite_ult:
                        self.ult_meter = min(self.ult_max, self.ult_meter + 10)

                    # Knockback
                    knockback = self.get_attack_knockback() + (opponent.damage * 0.2)
                    knockback = min(knockback, MAX_KNOCKBACK)

                    direction = 1 if self.x < opponent.x else -1

                    opponent.vx = knockback * direction
                    opponent.vy = -knockback * 0.5
                    opponent.hitstun = int(knockback * 1.5)
                    if not self.dev_one_hit_kill:
                        opponent.invincible = 15

    def check_ultimate_hit(self, opponents):
        attack_width = 150
        attack_height = 120
        attack_x = self.x - 50
        attack_y = self.y - 30

        for opponent in opponents:
            if opponent != self:
                if (attack_x < opponent.x + opponent.width and
                        attack_x + attack_width > opponent.x and
                        attack_y < opponent.y + opponent.height and
                        attack_y + attack_height > opponent.y):

                    damage = self.stats.ult_damage if not self.dev_one_hit_kill else 999
                    opponent.damage += damage

                    # Bigger hit effect for ultimate
                    for _ in range(5):
                        self.vfx.add_hit_effect(opponent.x + opponent.width // 2,
                                                opponent.y + opponent.height // 2,
                                                self.stats.ult_color)

                    knockback = (self.stats.ult_knockback if not self.dev_one_hit_kill else 999) + (
                                opponent.damage * 0.3)
                    knockback = min(knockback, MAX_KNOCKBACK * 1.5)

                    direction = 1 if self.x < opponent.x else -1

                    opponent.vx = knockback * direction * 1.5
                    opponent.vy = -knockback * 0.7
                    opponent.hitstun = int(knockback * 2)

    def respawn(self):
        self.x = SCREEN_WIDTH // 2 - self.width // 2
        self.y = SCREEN_HEIGHT // 2 - self.height
        self.vx = 0
        self.vy = 0
        self.damage = 0
        self.stocks -= 1
        self.invincible = 120
        self.ult_meter = 0
        self.ult_active = False

    def draw(self, screen):
        # Draw trail
        for i, pos in enumerate(self.trail):
            alpha = i * 25
            size = i // 2 + 2
            color = self.stats.ult_color
            pygame.draw.circle(screen, color, (int(pos[0]), int(pos[1])), size)

        # Draw VFX
        self.vfx.draw(screen)

        # Draw fighter
        color = self.stats.ult_color if self.ult_active else self.stats.color
        if self.invincible > 0 and (self.invincible // 5) % 2 == 0:
            color = WHITE

        # Special drawing for Jotaro/Star Platinum
        if self.stats.name == "Jotaro":
            # Draw hat
            pygame.draw.rect(screen, color, (self.x, self.y, self.width, self.height))
            pygame.draw.rect(screen, GOLD, (self.x + 5, self.y - 5, 26, 8))
            # Cape effect when ult active
            if self.ult_active:
                pygame.draw.polygon(screen, (150, 0, 150),
                                    [(self.x + self.width, self.y + 20),
                                     (self.x + self.width + 30, self.y + 30),
                                     (self.x + self.width, self.y + 40)])
        elif self.stats.name == "Star Platinum":
            # Bulkier body
            pygame.draw.rect(screen, color, (self.x, self.y, self.width, self.height))
            # Muscles
            pygame.draw.rect(screen, (100, 0, 200), (self.x + 5, self.y + 10, 10, 20))
            pygame.draw.rect(screen, (100, 0, 200), (self.x + 21, self.y + 10, 10, 20))
            # Stand aura
            if self.ult_active:
                for i in range(3):
                    pygame.draw.circle(screen, GOLD,
                                       (int(self.x + self.width // 2), int(self.y + self.height // 2)),
                                       30 + i * 10, 2)
        else:
            pygame.draw.rect(screen, color, (self.x, self.y, self.width, self.height))

        # Face direction indicator
        eye_x = self.x + (25 if self.facing > 0 else 10)
        pygame.draw.circle(screen, BLACK, (int(eye_x), int(self.y + 15)), 3)

        # Draw ultimate bar above head
        bar_width = 60
        bar_height = 6
        bar_x = self.x + self.width // 2 - bar_width // 2
        bar_y = self.y - 20

        # Background
        pygame.draw.rect(screen, DARK_GRAY, (bar_x, bar_y, bar_width, bar_height))
        # Fill
        fill_width = (self.ult_meter / self.ult_max) * bar_width
        if fill_width > 0:
            color = self.stats.ult_color
            pygame.draw.rect(screen, color, (bar_x, bar_y, fill_width, bar_height))
        # Border
        pygame.draw.rect(screen, WHITE, (bar_x, bar_y, bar_width, bar_height), 1)

        # Damage
        font = pygame.font.Font(None, 20)
        damage_color = RED if self.dev_one_hit_kill else WHITE
        text = font.render(f"{int(self.damage)}%", True, damage_color)
        screen.blit(text, (self.x + 5, self.y - 35))

        # Stocks
        for i in range(self.stocks):
            pygame.draw.circle(screen, color,
                               (int(self.x + 10 + i * 8), int(self.y - 50)), 4)

        # Dev mode indicators
