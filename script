        self.bg_left = Button(center_x - 100, start_y - 80, 50, 50, "<", DARK_GRAY, GRAY)
        self.bg_right = Button(center_x + 250, start_y - 80, 50, 50, ">", DARK_GRAY, GRAY)

        # AI difficulty
        self.ai_difficulty = 0.5
        self.show_difficulty = False

    def cycle_background(self, direction):
        self.background_index = (self.background_index + direction) % len(self.bg_list)
        self.current_bg = BACKGROUNDS[self.bg_list[self.background_index]]

    def run(self):
        while self.running:
            for event in pygame.event.get():
                if event.type == pygame.QUIT:
                    return None

                # Handle background cycle buttons
                if self.bg_left.handle_event(event):
                    self.cycle_background(-1)
                if self.bg_right.handle_event(event):
                    self.cycle_background(1)

                # Handle main buttons
                for i, button in enumerate(self.buttons):
                    if button.handle_event(event):
                        if i == 0:  # Local VS
                            return GameMode.LOCAL_VS
                        elif i == 1:  # VS AI
                            self.show_difficulty = True
                        elif i == 2:  # Dev Menu
                            return GameMode.DEV_MENU
                        elif i == 3:  # Settings
                            return "settings"
                        elif i == 4:  # Quit
                            return None

                if self.show_difficulty:
                    if event.type == pygame.KEYDOWN:
                        if event.key == pygame.K_LEFT:
                            self.ai_difficulty = max(0.1, self.ai_difficulty - 0.1)
                        elif event.key == pygame.K_RIGHT:
                            self.ai_difficulty = min(1.0, self.ai_difficulty + 0.1)
                        elif event.key == pygame.K_RETURN:
                            return GameMode.VS_AI
                        elif event.key == pygame.K_ESCAPE:
                            self.show_difficulty = False

            # Update background
            self.current_bg.update()

            # Draw everything
            self.current_bg.draw(self.screen)

            # Draw semi-transparent overlay
            overlay = pygame.Surface((SCREEN_WIDTH, SCREEN_HEIGHT))
            overlay.set_alpha(100)
            overlay.fill(BLACK)
