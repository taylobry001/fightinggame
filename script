# ==================== SIMPLIFIED FIGHTER ====================
class Fighter:
    def __init__(self, x, y, character_stats, player_id, is_ai=False):
        self.stats = character_stats
        self.id = player_id
        self.is_ai = is_ai
        
        # Position
        self.x = x
        self.y = y
        self.vx = 0
        self.vy = 0
        self.facing = 1
        self.on_ground = False
        self.jumps_left = 2
        
        # Combat
        self.damage = 0
        self.stocks = 3
        self.hitstun = 0
        self.invincible = 0
        
        # Ultimate system
        self.ult_meter = 0
        self.ult_max = 100
        self.ult_active = False
        self.ult_timer = 0
        self.ult_cooldown = 0
        
        # Input (simplified)
        self.move_left = False
        self.move_right = False
        self.press_jump = False
        self.press_attack = False
        self.press_special = False
        self.press_ult = False
        
        # Attack state
        self.attacking = False
        self.attack_type = 0  # 0=jab, 1=tilt, 2=smash, 3=special
        self.attack_timer = 0
        self.attack_cooldown = 0
        
        # Visual
        self.width = 36
        self.height = 54
        self.trail = []
        
    def update(self, platforms, opponents):
        # Hitstun
        if self.hitstun > 0:
            self.hitstun -= 1
            self.x += self.vx * 0.5
            self.y += self.vy * 0.5
            return
            
        # Invincibility
        if self.invincible > 0:
            self.invincible -= 1
            
        # Ultimate
        if self.ult_active:
            self.ult_timer -= 1
            if self.ult_timer <= 0:
                self.ult_active = False
                self.ult_cooldown = 300  # 5 seconds cooldown
                
        if self.ult_cooldown > 0:
            self.ult_cooldown -= 1
            
        # Attack cooldown
        if self.attack_cooldown > 0:
            self.attack_cooldown -= 1
            
        # Attack animation
        if self.attacking:
            self.attack_timer += 1
            if self.attack_timer > 15:  # Attack lasts 15 frames
                self.attacking = False
                self.attack_cooldown = 20
                
        # Movement
        move_input = 0
        if self.move_left:
            move_input = -1
        elif self.move_right:
            move_input = 1
            
        if move_input != 0:
            speed = self.stats.air_speed if not self.on_ground else self.stats.walk_speed
            self.vx += move_input * speed * 0.3
            self.facing = move_input
            
        # Friction
        if self.on_ground:
            self.vx *= GROUND_FRICTION
        else:
            self.vx *= AIR_FRICTION
            
        # Jump
        if self.press_jump and self.jumps_left > 0:
            if self.on_ground:
                self.vy = self.stats.jump_force
                self.jumps_left -= 1
                self.on_ground = False
            elif self.jumps_left > 0:
                self.vy = self.stats.double_jump_force
                self.jumps_left -= 1
            self.press_jump = False
            
        # Gravity
        if not self.on_ground:
            self.vy += GRAVITY
            
        # Apply movement
        self.x += self.vx
        self.y += self.vy
        
        # Platform collision
        self.on_ground = False
        for platform in platforms:
            if (self.x + self.width > platform[0] and 
                self.x < platform[0] + platform[2] and
                self.y + self.height > platform[1] and
                self.y + self.height < platform[1] + platform[3] + 10 and
                self.vy >= 0):
                self.y = platform[1] - self.height
                self.vy = 0
                self.on_ground = True
                self.jumps_left = 2
                break
                
        # Handle attacks
        if self.press_attack and not self.attacking and self.attack_cooldown <= 0:
            self.attack_type = 0  # jab
            self.attacking = True
            self.attack_timer = 0
            
        if self.press_special and not self.attacking and self.attack_cooldown <= 0:
            self.attack_type = 3  # special
            self.attacking = True
            self.attack_timer = 0
            
        # Ultimate
        if self.press_ult and self.ult_meter >= self.ult_max and self.ult_cooldown <= 0:
            self.ult_active = True
            self.ult_timer = 180  # 3 seconds
            self.ult_meter = 0
            
        # Ultimate generation (gain meter when dealing damage or taking damage)
        if self.ult_active:
            # Check for ultimate attack hit
            self.check_ultimate_hit(opponents)
            
        # Check for normal attack hits
        if self.attacking and 5 < self.attack_timer < 12:
            self.check_hits(opponents)
            
        # Trail effect for ultimate
        if self.ult_active:
            self.trail.append((self.x + self.width//2, self.y + self.height//2))
            if len(self.trail) > 10:
                self.trail.pop(0)
        else:
            self.trail = []
            
        # Blast zones
        if (self.x + self.width < BLAST_ZONES['left'] or 
            self.x > BLAST_ZONES['right'] or
            self.y + self.height < BLAST_ZONES['top'] or 
            self.y > BLAST_ZONES['bottom']):
            self.respawn()
            
    def get_attack_damage(self):
        if self.ult_active:
            return self.stats.ult_damage
            
        if self.attack_type == 0:
            return self.stats.jab_damage
        elif self.attack_type == 3:
            return self.stats.special_damage
        return 0
        
    def get_attack_knockback(self):
        if self.ult_active:
            return self.stats.ult_knockback
            
        if self.attack_type == 0:
            return self.stats.jab_knockback
        elif self.attack_type == 3:
            return self.stats.special_knockback
        return 0
        
    def check_hits(self, opponents):
        attack_width = 50
        attack_height = 40
        attack_x = self.x + (self.width if self.facing > 0 else -attack_width)
        attack_y = self.y + 10
        
        for opponent in opponents:
            if opponent != self and opponent.hitstun <= 0 and opponent.invincible <= 0:
                if (attack_x < opponent.x + opponent.width and
                    attack_x + attack_width > opponent.x and
                    attack_y < opponent.y + opponent.height and
                    attack_y + attack_height > opponent.y):
                    
                    # Damage
                    damage = self.get_attack_damage()
                    opponent.damage += damage
                    
                    # Gain ultimate meter
                    self.ult_meter = min(self.ult_max, self.ult_meter + 10)
                    
                    # Knockback
                    knockback = self.get_attack_knockback() + (opponent.damage * 0.2)
                    knockback = min(knockback, MAX_KNOCKBACK)
                    
                    direction = 1 if self.x < opponent.x else -1
                    
                    opponent.vx = knockback * direction
                    opponent.vy = -knockback * 0.5
                    opponent.hitstun = int(knockback * 1.5)
                    opponent.invincible = 15
                    
    def check_ultimate_hit(self, opponents):
        # Larger hitbox for ultimate
        attack_width = 100
        attack_height = 80
        attack_x = self.x - 30
        attack_y = self.y - 10
        
        for opponent in opponents:
            if opponent != self and opponent.hitstun <= 0:
                if (attack_x < opponent.x + opponent.width and
                    attack_x + attack_width > opponent.x and
                    attack_y < opponent.y + opponent.height and
                    attack_y + attack_height > opponent.y):
                    
                    damage = self.stats.ult_damage
                    opponent.damage += damage
                    
                    knockback = self.stats.ult_knockback + (opponent.damage * 0.3)
                    knockback = min(knockback, MAX_KNOCKBACK * 1.5)
                    
                    direction = 1 if self.x < opponent.x else -1
                    
                    opponent.vx = knockback * direction * 1.5
                    opponent.vy = -knockback * 0.7
                    opponent.hitstun = int(knockback * 2)
                    opponent.invincible = 30
                    
    def respawn(self):
        self.x = SCREEN_WIDTH // 2 - self.width // 2
        self.y = SCREEN_HEIGHT // 2 - self.height
        self.vx = 0
        self.vy = 0
        self.damage = 0
        self.stocks -= 1
        self.invincible = 120
        self.ult_meter = 0
        self.ult_active = False
        
    def draw(self, screen):
        # Draw trail
        for i, pos in enumerate(self.trail):
            alpha = i * 25
            size = i // 2 + 2
            color = self.stats.ult_color
            pygame.draw.circle(screen, color, (int(pos[0]), int(pos[1])), size)
            
        # Draw fighter
        color = self.stats.ult_color if self.ult_active else self.stats.color
        if self.invincible > 0 and (self.invincible // 5) % 2 == 0:
            color = WHITE
            
        pygame.draw.rect(screen, color, (self.x, self.y, self.width, self.height))
        
        # Face direction indicator
        eye_x = self.x + (25 if self.facing > 0 else 10)
        pygame.draw.circle(screen, BLACK, (int(eye_x), int(self.y + 15)), 3)
        
        # Draw ultimate bar above head
        bar_width = 60
        bar_height = 6
        bar_x = self.x + self.width//2 - bar_width//2
        bar_y = self.y - 15
        
        # Background
        pygame.draw.rect(screen, DARK_GRAY, (bar_x, bar_y, bar_width, bar_height))
        # Fill
        fill_width = (self.ult_meter / self.ult_max) * bar_width
        if fill_width > 0:
            color = self.stats.ult_color
            pygame.draw.rect(screen, color, (bar_x, bar_y, fill_width, bar_height))
        # Border
        pygame.draw.rect(screen, WHITE, (bar_x, bar_y, bar_width, bar_height), 1)
        
        # Damage
        font = pygame.font.Font(None, 20)
        text = font.render(f"{int(self.damage)}%", True, WHITE)
        screen.blit(text, (self.x + 5, self.y - 30))
        
        # Stocks
        for i in range(self.stocks):
            pygame.draw.circle(screen, color, 
                             (int(self.x + 10 + i * 8), int(self.y - 45)), 4)

# ==================== AI CONTROLLER (SIMPLIFIED) ====================
class AIController:
    def __init__(self, difficulty=0.5):
        self.difficulty = difficulty
        self.attack_timer = 0
        
    def get_inputs(self, ai_fighter, opponent):
        if not opponent or ai_fighter.hitstun > 0:
            return {'left': False, 'right': False, 'jump': False, 
                   'attack': False, 'special': False, 'ult': False}
            
        self.attack_timer = max(0, self.attack_timer - 1)
            
        dx = opponent.x - ai_fighter.x
        dy = opponent.y - ai_fighter.y
        distance = abs(dx)
        
        inputs = {'left': False, 'right': False, 'jump': False, 
                 'attack': False, 'special': False, 'ult': False}
        
        if random.random() < self.difficulty:
            # Movement
            if distance > 100:
                if dx > 0:
                    inputs['right'] = True
                else:
                    inputs['left'] = True
            elif distance < 50:
                if dx > 0:
                    inputs['left'] = True
                else:
                    inputs['right'] = True
                    
            # Jump
            if dy < -30 and ai_fighter.on_ground and random.random() < 0.05:
                inputs['jump'] = True
                
            # Attacks
            if distance < 80 and self.attack_timer == 0:
                if random.random() < 0.3:
                    inputs['attack'] = True
                    self.attack_timer = 30
                elif random.random() < 0.2:
                    inputs['special'] = True
                    self.attack_timer = 40
                    
            # Ultimate
            if ai_fighter.ult_meter >= ai_fighter.ult_max and random.random() < 0.1:
                inputs['ult'] = True
                
        return inputs

# ==================== ROOM SYSTEM ====================
class GameRoom:
    def __init__(self, room_id, host_name):
        self.room_id = room_id
        self.host_name = host_name
        self.players = [host_name]
        self.player_count = 1
        self.max_players = 2
        self.game_started = False
        self.selected_characters = {}
        
    def add_player(self, player_name):
        if self.player_count < self.max_players:
            self.players.append(player_name)
            self.player_count += 1
            return True
        return False
        
    def remove_player(self, player_name):
        if player_name in self.players:
            self.players.remove(player_name)
            self.player_count -= 1
            
    def select_character(self, player_name, character_index):
        self.selected_characters[player_name] = character_index
        
    def can_start(self):
        return self.player_count == self.max_players and len(self.selected_characters) == self.max_players

class RoomBrowser:
    def __init__(self, screen):
        self.screen = screen
        self.rooms = []
        self.selected_room = 0
        self.player_name = "Player" + str(random.randint(100, 999))
        
    def create_room(self):
        room_id = str(random.randint(1000, 9999))
        room = GameRoom(room_id, self.player_name)
        self.rooms.append(room)
        return room
        
    def join_room(self, room_id):
        for room in self.rooms:
            if room.room_id == room_id and not room.game_started:
                if room.add_player(self.player_name):
                    return room
        return None
        
    def draw(self):
        self.screen.fill(DARK_GRAY)
        
        font = pygame.font.Font(None, 48)
        title = font.render("GAME ROOMS", True, YELLOW)
        title_rect = title.get_rect(center=(SCREEN_WIDTH//2, 80))
        self.screen.blit(title, title_rect)
        
        # Draw rooms
        y = 150
        for i, room in enumerate(self.rooms):
            color = GREEN if i == self.selected_room else WHITE
            room_text = f"Room {room.room_id} - {room.player_count}/2 players - Host: {room.host_name}"
            text = pygame.font.Font(None, 36).render(room_text, True, color)
            self.screen.blit(text, (200, y))
            y += 50
            
        # Instructions
        small_font = pygame.font.Font(None, 24)
        inst1 = small_font.render("UP/DOWN: Select Room, ENTER: Join Selected, C: Create Room", True, LIGHT_GRAY)
        inst2 = small_font.render(f"Your name: {self.player_name}", True, LIGHT_GRAY)
        self.screen.blit(inst1, (SCREEN_WIDTH//2 - inst1.get_width()//2, 500))
        self.screen.blit(inst2, (SCREEN_WIDTH//2 - inst2.get_width()//2, 530))
        
        pygame.display.flip()

# ==================== SETTINGS MENU ====================
class SettingsMenu:
    def __init__(self, screen):
        self.screen = screen
        self.running = True
        
        # Settings
        self.volume = 50
        self.music_enabled = True
        self.sound_enabled = True
        self.screen_shake = True
        self.particle_effects = True
        self.selected_bg = "dojo"
        
        self.selected_option = 0
        self.options = [
            "Background: " + self.selected_bg,
            f"Volume: {self.volume}%",
            f"Music: {'ON' if self.music_enabled else 'OFF'}",
            f"Sound: {'ON' if self.sound_enabled else 'OFF'}",
            f"Screen Shake: {'ON' if self.screen_shake else 'OFF'}",
            f"Particles: {'ON' if self.particle_effects else 'OFF'}",
            "Back"
        ]
        
    def handle_input(self, keys):
        if keys[pygame.K_UP]:
            self.selected_option = (self.selected_option - 1) % len(self.options)
            pygame.time.wait(200)
        elif keys[pygame.K_DOWN]:
            self.selected_option = (self.selected_option + 1) % len(self.options)
            pygame.time.wait(200)
        elif keys[pygame.K_LEFT]:
            self.adjust_setting(-1)
        elif keys[pygame.K_RIGHT]:
            self.adjust_setting(1)
        elif keys[pygame.K_RETURN]:
            if self.selected_option == len(self.options) - 1:  # Back
                self.running = False
                
    def adjust_setting(self, direction):
        if self.selected_option == 0:  # Background
            bg_list = list(BACKGROUNDS.keys())
            current_index = bg_list.index(self.selected_bg)
            new_index = (current_index + direction) % len(bg_list)
            self.selected_bg = bg_list[new_index]
            self.options[0] = "Background: " + self.selected_bg
            
        elif self.selected_option == 1:  # Volume
            self.volume = max(0, min(100, self.volume + direction * 10))
            self.options[1] = f"Volume: {self.volume}%"
            
        elif self.selected_option == 2:  # Music
            self.music_enabled = not self.music_enabled
            self.options[2] = f"Music: {'ON' if self.music_enabled else 'OFF'}"
            
        elif self.selected_option == 3:  # Sound
            self.sound_enabled = not self.sound_enabled
            self.options[3] = f"Sound: {'ON' if self.sound_enabled else 'OFF'}"
            
        elif self.selected_option == 4:  # Screen Shake
            self.screen_shake = not self.screen_shake
            self.options[4] = f"Screen Shake: {'ON' if self.screen_shake else 'OFF'}"
            
        elif self.selected_option == 5:  # Particles
