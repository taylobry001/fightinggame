<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Combo Clash: Y2K Edition</title>
<style>
body{margin:0;overflow:hidden;font-family:sans-serif;background:#111;color:white;}
canvas{display:block;margin:0 auto;border:2px solid #555;background:#222;}
#settings{position:absolute;top:10px;left:10px;background:rgba(0,0,0,0.5);padding:10px;border-radius:8px;}
label{margin-right:10px;}
</style>
</head>
<body>
<div id="settings">
<label>Background:
<select id="bgSelect"></select>
</label>
<label>Character:
<select id="charSelect">
<option value="cyan">Cyan Fighter</option>
<option value="magenta">Magenta Ninja</option>
<option value="lime">Lime Warrior</option>
</select>
</label>
<label>Difficulty:
<input type="range" id="diffSlider" min="1" max="5" value="3">
</label>
<button id="pauseBtn">Pause</button>
<button id="restartBtn">Restart</button>
</div>
<canvas id="gameCanvas" width="800" height="400"></canvas>
<script>
const canvas=document.getElementById('gameCanvas');
const ctx=canvas.getContext('2d');
const keys={};
document.addEventListener('keydown',e=>keys[e.key.toLowerCase()]=true);
document.addEventListener('keyup',e=>keys[e.key.toLowerCase()]=false);

const bgSelect=document.getElementById('bgSelect');
const backgrounds=[
"Glassy Sky & Bubbles","Water + Fish + Light Rays","Sunlit Ocean Waves + Aurora","Grassy Horizon + Floating Particles",
"Shiny Chrome Grid","Vector Neon Scans","Cyber Glitter","Futuristic UI Lines",
"Galaxy Stars & Nebula","Aurora Cosmic Trails","Shooting Stars + Sparkles","Holographic Orbs",
"Pastel Gradient Waves","Bokeh Lights","Glossy Spheres","Neon Bloom",
"Glass + Lens Flares","Floating Glass Planets","Crystalline Water Glow","Soft Haze Glow Gradients"
];
backgrounds.forEach(b=>{let opt=document.createElement('option');opt.value=b;opt.text=b;bgSelect.appendChild(opt);});
let bgMode=bgSelect.value;
bgSelect.addEventListener('change',()=>bgMode=bgSelect.value);

const charSelect=document.getElementById('charSelect');
let playerColor=charSelect.value;

const diffSlider=document.getElementById('diffSlider');
const pauseBtn=document.getElementById('pauseBtn');
const restartBtn=document.getElementById('restartBtn');
let paused=false;
pauseBtn.addEventListener('click',()=>paused=!paused);
restartBtn.addEventListener('click',()=>resetGame());

class Particle{constructor(x,y,dx,dy,color,lifetime){this.x=x;this.y=y;this.dx=dx;this.dy=dy;this.color=color;this.lifetime=lifetime;}
update(){this.x+=this.dx;this.y+=this.dy;this.lifetime--;}
draw(){ctx.fillStyle=this.color;ctx.globalAlpha=this.lifetime/50;ctx.fillRect(this.x,this.y,4,4);ctx.globalAlpha=1;}}

let particles=[],worldParticles=[],shootingStars=[],screenShake=0;
for(let i=0;i<100;i++){worldParticles.push({x:Math.random()*canvas.width,y:Math.random()*canvas.height,size:Math.random()*3+1,dx:Math.random()*0.5-0.25,dy:Math.random()*0.5-0.25,color:`hsl(${Math.random()*360},80%,70%)`});}

class Fighter{
constructor(x,y,color,isAI=false){this.x=x;this.y=y;this.width=50;this.height=80;this.color=color;this.health=100;this.speed=4;this.isAI=isAI;this.combo=0;this.attackTimer=0;this.name=color;}
draw(){ctx.fillStyle=this.color;ctx.fillRect(this.x,this.y,this.width,this.height);
ctx.fillStyle='red';ctx.fillRect(this.x,this.y-10,this.width,5);
ctx.fillStyle='lime';ctx.fillRect(this.x,this.y-10,this.width*(this.health/100),5);
ctx.fillStyle='blue';ctx.fillRect(this.x,this.y-20,this.width*(this.combo/10),5);
if(this.combo>1){ctx.fillStyle='yellow';ctx.font='20px sans-serif';ctx.fillText(this.combo+' HIT!',this.x,this.y-30);}}
attack(opponent,type='punch'){if(this.attackTimer>0)return;let damage=type==='punch'?5:8;if(Math.abs(this.x-opponent.x)<60){opponent.health-=damage;this.combo=Math.min(10,this.combo+1);screenShake=5;for(let i=0;i<10;i++)particles.push(new Particle(opponent.x+25,opponent.y+40,Math.random()*4-2,Math.random()*-2-1,'yellow',30));}this.attackTimer=20;}
special(opponent){if(Math.abs(this.x-opponent.x)<100){opponent.health-=25;screenShake=10;for(let i=0;i<30;i++)particles.push(new Particle(opponent.x+25,opponent.y+40,Math.random()*6-3,Math.random()*-3-1,'cyan',50));}this.combo=0;this.attackTimer=40;}
update(opponent,difficulty){if(this.isAI){let speed=this.speed+(difficulty-3)/2;if(this.x<opponent.x-10)this.x+=speed;if(this.x>opponent.x+10)this.x-=speed;if(Math.abs(this.x-opponent.x)<60&&this.attackTimer<=0){if(Math.random()<0.05*difficulty)this.attack(opponent);}this.attackTimer--;}
else{if(keys['arrowleft'])this.x-=this.speed;if(keys['arrowright'])this.x+=this.speed;if(keys['z'])this.attack(opponent,'punch');if(keys['x'])this.attack(opponent,'kick');if(keys['c']&&this.combo>=10)this.special(opponent);}
this.x=Math.max(0,Math.min(canvas.width-this.width,this.x));}}

let player=new Fighter(100,300,playerColor);
let enemy=new Fighter(600,300,'orange',true);

function spawnShootingStar(){shootingStars.push({x:Math.random()*canvas.width,y:0,length:Math.random()*100+50,speed:Math.random()*6+4,angle:Math.random()*0.3+0.1});}

function drawBG(){
const t=Date.now()/1000;
switch(bgMode){
case "Glassy Sky & Bubbles":ctx.fillStyle=`hsl(${t*50%360},80%,70%)`;ctx.fillRect(0,0,canvas.width,canvas.height);for(let i=0;i<50;i++){ctx.fillStyle=`hsla(${i*10+t*20},80%,70%,0.3)`;ctx.beginPath();ctx.arc(Math.sin(t+i)*canvas.width/2+canvas.width/2,Math.cos(t+i)*canvas.height/2+canvas.height/2,5+Math.sin(t+i)*3,0,2*Math.PI);ctx.fill();}break;
case "Water + Fish + Light Rays":ctx.fillStyle='rgba(0,100,255,0.2)';ctx.fillRect(0,0,canvas.width,canvas.height);for(let p of worldParticles){p.x+=p.dx;p.y+=p.dy;if(p.x>canvas.width)p.x=0;if(p.x<0)p.x=canvas.width;if(p.y>canvas.height)p.y=0;if(p.y<0)p.y=canvas.height;ctx.fillStyle=p.color;ctx.fillRect(p.x,p.y,p.size,p.size);}break;
case "Sunlit Ocean Waves + Aurora":ctx.fillStyle=`linear-gradient(0,0,${canvas.width},${canvas.height})`;ctx.fillRect(0,0,canvas.width,canvas.height);for(let i=0;i<worldParticles.length;i++){const p=worldParticles[i];p.x+=Math.sin(t+i)*0.5;p.y+=Math.cos(t+i)*0.3;ctx.fillStyle=p.color;ctx.fillRect(p.x,p.y,p.size,p.size);}break;
case "Grassy Horizon + Floating Particles":ctx.fillStyle='green';ctx.fillRect(0,canvas.height/2,canvas.width,canvas.height/2);for(let i=0;i<50;i++){ctx.fillStyle=`hsl(${i*20+t*30},80%,50%)`;ctx.fillRect(Math.random()*canvas.width,canvas.height/2+Math.random()*canvas.height/2,3,3);}break;
case "Shiny Chrome Grid":ctx.fillStyle='black';ctx.fillRect(0,0,canvas.width,canvas.height);ctx.strokeStyle='silver';for(let i=0;i<canvas.width;i+=40){ctx.beginPath();ctx.moveTo(i,0);ctx.lineTo(i,canvas.height);ctx.stroke();}for(let i=0;i<canvas.height;i+=40){ctx.beginPath();ctx.moveTo(0,i);ctx.lineTo(canvas.width,i);ctx.stroke();}break;
case "Vector Neon Scans":ctx.fillStyle='black';ctx.fillRect(0,0,canvas.width,canvas.height);ctx.strokeStyle=`hsl(${t*60%360},100%,50%)`;for(let i=0;i<canvas.width;i+=30){ctx.beginPath();ctx.moveTo(i,(t*20)%canvas.height);ctx.lineTo(i,canvas.height);ctx.stroke();}for(let i=0;i<canvas.height;i+=30){ctx.beginPath();ctx.moveTo(0,(i+t*20)%canvas.height);ctx.lineTo(canvas.width,(i+t*20)%canvas.height);ctx.stroke();}break;
case "Cyber Glitter":ctx.fillStyle='black';ctx.fillRect(0,0,canvas.width,canvas.height);for(let i=0;i<worldParticles.length;i++){const p=worldParticles[i];ctx.fillStyle=p.color;ctx.fillRect(p.x,p.y,p.size,p.size);p.x+=Math.random()*0.5-0.25;p.y+=Math.random()*0.5-0.25;}break;
case "Futuristic UI Lines":ctx.fillStyle='black';ctx.fillRect(0,0,canvas.width,canvas.height);ctx.strokeStyle='cyan';for(let i=0;i<canvas.width;i+=50){ctx.beginPath();ctx.moveTo(i,0);ctx.lineTo(i,canvas.height);ctx.stroke();}for(let i=0;i<canvas.height;i+=50){ctx.beginPath();ctx.moveTo(0,i);ctx.lineTo(canvas.width,i);ctx.stroke();}break;
case "Galaxy Stars & Nebula":ctx.fillStyle='rgba(5,5,30,1)';ctx.fillRect(0,0,canvas.width,canvas.height);for(let p of worldParticles){ctx.fillStyle='white';ctx.fillRect(p.x,p.y,p.size,p.size);}if(Math.random()<0.02)spawnShootingStar();for(let i=shootingStars.length-1;i>=0;i--){const s=shootingStars[i];ctx.strokeStyle='white';ctx.beginPath();ctx.moveTo(s.x,s.y);ctx.lineTo(s.x-s.length*Math.cos(s.angle),s.y-s.length*Math.sin(s.angle));ctx.stroke();s.x+=s.speed*Math.cos(s.angle);s.y+=s.speed*Math.sin(s.angle);if(s.x>canvas.width||s.y>canvas.height)shootingStars.splice(i,1);}break;
case "Aurora Cosmic Trails":ctx.fillStyle='black';ctx.fillRect(0,0,canvas.width,canvas.height);for(let i=0;i<worldParticles.length;i++){const p=worldParticles[i];ctx.fillStyle=p.color;ctx.fillRect(p.x,p.y,p.size,p.size);p.x+=Math.sin(t+i)*0.3;p.y+=Math.cos(t+i)*0.3;}break;
case "Shooting Stars + Sparkles":ctx.fillStyle='black';ctx.fillRect(0,0,canvas.width,canvas.height);if(Math.random()<0.03)spawnShootingStar();for(let i=shootingStars.length-1;i>=0;i--){const s=shootingStars[i];ctx.strokeStyle='white';ctx.beginPath();ctx.moveTo(s.x,s.y);ctx.lineTo(s.x-s.length*Math.cos(s.angle),s.y-s.length*Math.sin(s.angle));ctx.stroke();s.x+=s.speed*Math.cos(s.angle);s.y+=s.speed*Math.sin(s.angle);if(s.x>canvas.width||s.y>canvas.height)shootingStars.splice(i,1);}break;
case "Holographic Orbs":ctx.fillStyle='black';ctx.fillRect(0,0,canvas.width,canvas.height);for(let i=0;i<worldParticles.length;i++){const p=worldParticles[i];ctx.fillStyle=`hsla(${i*10+t*30},80%,70%,0.5)`;ctx.beginPath();ctx.arc(p.x,p.y,p.size*2,0,Math.PI*2);ctx.fill();}break;
case "Pastel Gradient Waves":const grad1=ctx.createLinearGradient(0,0,canvas.width,canvas.height);grad1.addColorStop(0,'#FF9FF3');grad1.addColorStop(0.5,'#Feca57');grad1.addColorStop(1,'#48dbfb');ctx.fillStyle=grad1;ctx.fillRect(0,0,canvas.width,canvas.height);break;
case "Bokeh Lights":ctx.fillStyle='black';ctx.fillRect(0,0,canvas.width,canvas.height);for(let i=0;i<50;i++){ctx.fillStyle=`hsla(${Math.random()*360},80%,70%,0.3)`;ctx.beginPath();ctx.arc(Math.random()*canvas.width,Math.random()*canvas.height,Math.random()*15+5,0,2*Math.PI);ctx.fill();}break;
case "Glossy Spheres":ctx.fillStyle='black';ctx.fillRect(0,0,canvas.width,canvas.height);for(let i=0;i<30;i++){ctx.fillStyle=`hsl(${i*30+t*50%360},80%,70%)`;ctx.beginPath();ctx.arc(Math.random()*canvas.width,Math.random()*canvas.height,Math.random()*20+5,0,2*Math.PI);ctx.fill();}break;
case "Neon Bloom":ctx.fillStyle='black';ctx.fillRect(0,0,canvas.width,canvas.height);for(let i=0;i<50;i++){ctx.strokeStyle=`hsl(${i*20+t*40%360},100%,50%)`;ctx.beginPath();ctx.arc(Math.random()*canvas.width,Math.random()*canvas.height,Math.random()*30+10,0,2*Math.PI);ctx.stroke();}break;
case "Glass + Lens Flares":ctx.fillStyle='rgba(200,255,255,0.1)';ctx.fillRect(0,0,canvas.width,canvas.height);for(let i=0;i<10;i++){ctx.fillStyle=`hsla(${t*30+i*36},80%,70%,0.2)`;ctx.beginPath();ctx.arc(Math.random()*canvas.width,Math.random()*canvas.height,Math.random()*80+20,0,2*Math.PI);ctx.fill();}break;
case "Floating Glass Planets":ctx.fillStyle='black';ctx.fillRect(0,0,canvas.width,canvas.height);for(let i=0;i<10;i++){ctx.fillStyle=`hsla(${i*36+t*50},70%,70%,0.3)`;ctx.beginPath();ctx.arc(Math.sin(t+i)*canvas.width/2+canvas.width/2,Math.cos(t+i)*canvas.height/2+canvas.height/2,Math.random()*30+10,0,2*Math.PI);ctx.fill();}break;
case "Crystalline Water Glow":ctx.fillStyle='rgba(0,100,255,0.2)';ctx.fillRect(0,0,canvas.width,canvas.height);for(let i=0;i<50;i++){ctx.fillStyle=`hsla(${i*30+t*20},70%,70%,0.3)`;ctx.fillRect(Math.random()*canvas.width,Math.random()*canvas.height,Math.random()*5+2,Math.random()*5+2);}}}

function updateParticles(){particles=particles.filter(p=>p.lifetime>0);particles.forEach(p=>p.update());}

function update(){const diff=parseInt(diffSlider.value);player.update(enemy,diff);enemy.update(player,diff);updateParticles();}

function draw(){if(screenShake>0){ctx.save();ctx.translate(Math.random()*screenShake,Math.random()*screenShake);screenShake--;}drawBG();player.draw();enemy.draw();if(screenShake>0)ctx.restore();}

function loop(){if(!paused){update();draw();if(player.health<=0||enemy.health<=0){ctx.fillStyle='white';ctx.font='40px sans-serif';ctx.fillText(player.health>0?"You Win!":"AI Wins!",300,200);setTimeout(()=>resetGame(),2000);return;}}requestAnimationFrame(loop);}

function resetGame(){player=new Fighter(100,300,charSelect.value);enemy=new Fighter(600,300,'orange',true);particles=[];screenShake=0;}

loop();
</script>
</body>
</html>
